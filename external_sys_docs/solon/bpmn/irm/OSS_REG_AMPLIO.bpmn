    <bpmn:serviceTask id="PostForm" name="Post Form" zeebe:modelerTemplate="transitionFormStatusCommand" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
