{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Transition Process Flow Status",
  "id": "transitionProcessFlowCommand",
  "description": "Sends a command to transition the status of process flow",
  "version": 1,
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "PublishTransitionProcessFlowCommand",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "Process Flow ID",
      "description": "The id of process flow",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "processFlowId"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Status",
      "description": "The status for the process flow to transition to",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityStatusCL"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Process Type Code",
      "description": "Process Type of the process flow",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "processTypeCode"
      },
      "constraints": {
        "notEmpty": true
      }
    }
  ]
}