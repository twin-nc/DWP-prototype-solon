    <bpmn:serviceTask id="Activity_038j0wu" name="Send Warrant Letter">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="PublishCreateContactCommand" />
        <zeebe:ioMapping>
          <zeebe:input source="=caseId" target="entityId" />
          <zeebe:input source="=&#34;WARANTLETR&#34;" target="contactTypeCode" />
          <zeebe:input source="=&#34;EMAIL_OUT&#34;" target="communicationChannelCode" />
          <zeebe:input source="=&#34;CREATE_CONTACT_LETTER&#34;" target="signalName" />
          <zeebe:input source="=processInstanceId" target="processInstanceId" />
          <zeebe:input source="= [&#10;   { &#10;     name: &#34;case_id&#34;, &#10;     value : caseId &#10;   },&#10;   { &#10;     name: &#34;case_balance&#34;, &#10;     value : response.totalCaseBalance.amount&#10;   },&#10;   { &#10;     name: &#34;pid&#34;, &#10;     value : processInstanceId&#10;   },&#10;   { &#10;     name: &#34;case_liability_bill_segments&#34;, &#10;     value : billSegmentData&#10;   },&#10;   { &#10;     name: &#34;liability&#34;, &#10;     value : firstLiabilityId&#10;   },&#10;   { &#10;     name: &#34;fee&#34;, &#10;     value : fee&#10;   }&#10; ]" target="parameters" />
          <zeebe:input source="=[&#10;  {&#10;    entityId : caseId,&#10;    entityCL : &#34;Case&#34;&#10;  }&#10;]" target="relatedEntities" />
          <zeebe:input source="=billSegmentResult.partyRoleId" target="partyRoleId" />
          <zeebe:input source="=&#34;Case&#34;" target="entityCL" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_01oa8la</bpmn:incoming>
      <bpmn:outgoing>Flow_0c7tui1</bpmn:outgoing>
    </bpmn:serviceTask>
