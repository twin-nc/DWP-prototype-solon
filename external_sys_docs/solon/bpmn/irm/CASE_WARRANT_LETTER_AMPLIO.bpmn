          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="={&#10;  &#34;caseEntityRelationshipTypeCL&#34;: &#34;RELATED_CONTACTS&#34;,&#10;  &#34;entityCL&#34;: &#34;Contact&#34;,&#10;  &#34;entityId&#34;: contactId&#10;}" target="body" />
