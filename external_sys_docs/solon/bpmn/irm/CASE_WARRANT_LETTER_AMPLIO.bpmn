    <bpmn:sequenceFlow id="Flow_1dovi9w" sourceRef="CaseWarrantLetterStartEvent" targetRef="ProcessInitializer" />
    <bpmn:serviceTask id="ConfigureCaseScope" name="Configure Case Scope">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ConfigureCaseScopeCommand" />
        <zeebe:ioMapping>
          <zeebe:input source="=caseId" target="caseId" />
