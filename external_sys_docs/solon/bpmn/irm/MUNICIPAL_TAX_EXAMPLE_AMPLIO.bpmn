        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" />
          <zeebe:header key="resultExpression" value="={&#10;  assessment_id : response.body.id,&#10;  responseStatus : response.status,&#10;  assessment_status : response.body.assessmentStatusCL,&#10;  bill_id : response.body.bill.id&#10;}" />
