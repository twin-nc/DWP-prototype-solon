        <zeebe:ioMapping>
          <zeebe:input source="oauth-client-credentials-flow" target="authentication.type" />
          <zeebe:input source="put" target="method" />
          <zeebe:input source="=&#34;{{secrets.API_GATEWAY_URL}}/taxpayer-accounting/assessments/&#34; + subject_to_cancel_assessment_id + &#34;/cancel&#34;" target="url" />
          <zeebe:input source="=if contextToken != null then {&#34;solon-context-token&#34;: contextToken} else {}" target="headers" />
