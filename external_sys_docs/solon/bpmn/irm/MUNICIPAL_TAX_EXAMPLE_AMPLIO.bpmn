          <zeebe:input source="basicAuthHeader" target="authentication.clientAuthentication" />
          <zeebe:input source="150" target="connectionTimeoutInSeconds" />
          <zeebe:input source="={&#10;    &#34;obligation&#34;: {&#10;        &#34;id&#34;: obligation_id&#10;    },&#10;    &#34;assessmentTypeCode&#34;: assessment_type_code,&#10;    &#34;assessmentBillBehaviorCL&#34;: &#34;CREATE_NEW_BILL&#34;,&#10;    &#34;changeReasonCL&#34;: &#34;ReadyForCompletion&#34;,&#10;    &#34;changeReasonComment&#34;: &#34;By Batch &#34; + task + &#34;, ran: &#34; + string(date(now())),&#10;    &#34;assessmentRelatedEntities&#34;:if subject_to_cancel_assessment_id=null then null else [{&#10;      &#34;entityCL&#34;:&#34;Assessment&#34;,&#10;      &#34;entityId&#34;:canceled_assessment_id,&#10;      &#34;assessmentRelatedEntityRelationshipCL&#34;:&#34;OVERRIDE_CANCELED_ASSESSMENT&#34;&#10;      },{&#34;entityCL&#34;:&#34;ProcessInstance&#34;,&#10;      &#34;entityId&#34;:processInstanceId,&#10;      &#34;assessmentRelatedEntityRelationshipCL&#34;:&#34;GENERATED_BY&#34;}]&#10;}" target="body" />
