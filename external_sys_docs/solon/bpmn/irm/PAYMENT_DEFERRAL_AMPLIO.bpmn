      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
        <zeebe:ioMapping>
          <zeebe:input source="oauth-client-credentials-flow" target="authentication.type" />
          <zeebe:input source="get" target="method" />
          <zeebe:input source="=&#34;{{secrets.API_GATEWAY_URL}}/ui-configuration/forms/&#34; + entityId" target="url" />
          <zeebe:input source="=if contextToken != null then {&#34;solon-context-token&#34;: contextToken} else {}" target="headers" />
