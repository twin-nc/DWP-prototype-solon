    <bpmn:serviceTask id="SendReportContact" name="Send Contact with Report">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="PublishCreateContactCommand" />
        <zeebe:ioMapping>
          <zeebe:input source="=entityId" target="entityId" />
          <zeebe:input source="=relatedEntities[2].entityId" target="contactTypeCode" />
          <zeebe:input source="=&#34;EMAIL_OUT&#34;" target="communicationChannelCode" />
          <zeebe:input source="=&#34;CREATE_CONTACT_EMAIL_REPORT_SENT&#34;" target="signalName" />
          <zeebe:input source="=processInstanceId" target="processInstanceId" />
          <zeebe:input source="= [&#10;   { &#10;     name: &#34;attachment_id&#34;, &#10;     value : attachmentId,&#10;     attributes: {&#10;       &#34;ATTACH_TO_CONTACT&#34;:true&#10;     }&#10;   }&#10; ]" target="parameters" />
          <zeebe:input source="=[&#10;  {&#10;    entityId :attachmentId,&#10;    entityCL :&#34;Attachment&#34;&#10;  }&#10;]" target="relatedEntities" />
          <zeebe:input source="=recipientPartyRoleId.id" target="partyRoleId" />
          <zeebe:input source="=&#34;ScheduledProcess&#34;" target="entityCL" />
        </zeebe:ioMapping>
