    <bpmn:serviceTask id="Activity_0tvhy9s" name="Update Process Flow" zeebe:modelerTemplate="transitionProcessFlowCommand" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
