<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0mma1ku" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.32.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.2.0">
  <bpmn:process id="ProcessDefinitions.O_PLN_PRVL_AMPLIO" name="O_PLN_PRVL_AMPLIO" isExecutable="true">
    <bpmn:startEvent id="OPlnPrvlStartEvent" name="O Pln Prvl Start Event">
      <bpmn:outgoing>Flow_1n86qvh</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1n86qvh" sourceRef="OPlnPrvlStartEvent" targetRef="ProcessInitializer" />
    <bpmn:serviceTask id="CreateHumanTask" name="Create Human Task" zeebe:modelerTemplate="createHumanTaskCommand" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="CreateHumanTaskCommand" />
        <zeebe:ioMapping>
          <zeebe:input source="=entityId" target="entityId" />
          <zeebe:input source="=processInstanceId" target="processInstanceId" />
          <zeebe:input source="=&#34;OPPLNAPPTK&#34;" target="humanTaskTypeCode" />
          <zeebe:input source="=&#34;PRIORITY_10&#34;" target="humanTaskPriorityCL" />
          <zeebe:input source="=[&#10;  {&#10;    humanTaskEntityRelationshipTypeCL : &#34;BELONGING&#34;,&#10;    entityCL : &#34;ProcessFlow&#34;,&#10;    entityId : entityId&#10;  },&#10;  {&#10;    humanTaskEntityRelationshipTypeCL : &#34;BELONGING&#34;,&#10;    entityCL : &#34;ProcessInstance&#34;,&#10;    entityId : processInstanceId&#10;  }&#10;]" target="relatedEntities" />
          <zeebe:input source="=&#34;Zeebe created for entityId &#34; + entityId" target="comment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ffo53s</bpmn:incoming>
      <bpmn:outgoing>Flow_196b8h1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1ffo53s" sourceRef="GetProcessFlowById" targetRef="CreateHumanTask" />
    <bpmn:eventBasedGateway id="HumanTaskResultGateway">
