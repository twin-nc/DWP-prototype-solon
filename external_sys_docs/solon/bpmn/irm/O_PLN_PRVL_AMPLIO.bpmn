      <bpmn:outgoing>Flow_0hnt2ca</bpmn:outgoing>
      <bpmn:outgoing>Flow_1oyx61l</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_196b8h1" sourceRef="CreateHumanTask" targetRef="HumanTaskResultGateway" />
    <bpmn:intermediateCatchEvent id="OpplnapptkPendingSignal" name="OPPLNAPPTK_PENDING_SIGNAL">
      <bpmn:extensionElements>
        <zeebe:properties />
        <zeebe:ioMapping>
          <zeebe:output source="=&#34;PENDING&#34;" target="processFlowStatus" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0hnt2ca</bpmn:incoming>
      <bpmn:outgoing>Flow_0y3i2vh</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1wfwhi7" messageRef="Message_01umc4r" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="OpplnapptkInProgressSignal" name="OPPLNAPPTK_IN_PROGRESS_SIGNAL">
