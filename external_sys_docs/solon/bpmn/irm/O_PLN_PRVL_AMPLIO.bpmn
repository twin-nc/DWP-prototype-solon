        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1qdyy0x</bpmn:incoming>
      <bpmn:outgoing>Flow_1ib0ukw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1qdyy0x" sourceRef="Gateway_1gulwzp" targetRef="Activity_0tvhy9s" />
    <bpmn:endEvent id="Event_09ye133">
