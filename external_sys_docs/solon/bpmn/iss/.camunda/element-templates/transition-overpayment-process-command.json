{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Transition Overpayment Process Status",
  "id": "transitionOverpaymentProcessCommand",
  "description": "Sends a command to transition the status of overpayment process",
  "version": 1,
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "PublishTransitionOverpaymentProcessCommand",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "Overpayment Process ID",
      "description": "The id of overpayment process",
      "value": "overpaymentProcessId",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "overpaymentProcessId"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Status",
      "description": "The status for the overpayment process to transition to",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "statusCL"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Signal Name",
      "description": "The signal name that the process expects after the status is transitioned",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "signalName"
      },
      "constraints": {
        "notEmpty": true
      }
    }
  ]
}