{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Push Notification",
  "id": "pushNotificationCommand",
  "description": "Sends a command to push a notification",
  "version": 1,
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "PublishPushNotificationCommand",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "Entity ID",
      "description": "The entity id to associate the notification with",
      "value": "=entityId",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityId"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Entity CL",
      "description": "Entity CL tha describes the entity type",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityCL"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Entity Status CL",
      "description": "Status of the entity",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityStatusCL"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Notification Type Code",
      "description": "Code of the notification type",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "notificationTypeCode"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "User",
      "description": "Username of the user that submitted the form",
      "value": "=user",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "user"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Title Key",
      "description": "Key for the title to use for the notification",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "titleKey"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Message Key",
      "description": "Key for the message to use for the notification",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "messageKey"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Message Codelists",
      "description": "Codelists to use for the message. Should always be an array",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "messageCodelists"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Message Parameters",
      "description": "Parameters to use for the message. Should always be an array",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "messageParams"
      },
      "constraints": {
        "notEmpty": true
      }
    }
  ]
}