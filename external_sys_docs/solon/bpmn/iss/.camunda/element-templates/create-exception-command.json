{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Create Exception",
  "id": "createExceptionCommand",
  "description": "Sends a command to create an exception",
  "version": 1,
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "CreateExceptionCommand",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "Entity ID",
      "description": "The entity id to associate the exception with",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityId"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Entity CL",
      "description": "Entity CL tha describes the entity type",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "entityCL"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Exception Type Code",
      "description": "The code of the exception type",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": false,
      "binding": {
        "type": "zeebe:input",
        "name": "exceptionTypeCode"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "label": "Source Entity ID",
      "description": "The source entity id",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": true,
      "binding": {
        "type": "zeebe:input",
        "name": "sourceEntityId"
      }
    },
    {
      "label": "Comment",
      "description": "Comment for the exception",
      "value": "",
      "type": "String",
      "feel" : "optional",
      "optional": true,
      "binding": {
        "type": "zeebe:input",
        "name": "comment"
      }
    }
  ]
}