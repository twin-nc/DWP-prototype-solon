# Port the frontend listens on (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Spring profile: local | dev (default: local)
SPRING_PROFILES_ACTIVE=local

# PostgreSQL connection string (used by backend)
DATABASE_URL=postgresql://dcms:dcms@db:5432/dcms

# Keycloak issuer URI (backend JWT validation)
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/dcms
