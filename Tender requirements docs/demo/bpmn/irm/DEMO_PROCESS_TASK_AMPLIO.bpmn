  <bpmn:process id="ProcessDefinitions.DEMO_PROCESS_TASK_AMPLIO" name="DEMO_PROCESS_TASK_AMPLIO" isExecutable="true">
    <bpmn:serviceTask id="CreateHumanTask" name="Create Human Task" zeebe:modelerTemplate="createHumanTaskCommand" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="CreateHumanTaskCommand" />
        <zeebe:ioMapping>
          <zeebe:input source="=entityId" target="entityId" />
          <zeebe:input source="=processInstanceId" target="processInstanceId" />
          <zeebe:input source="=&#34;&#34;" target="signalName" />
          <zeebe:input source="=&#34;PROC_TASK&#34;" target="humanTaskTypeCode" />
          <zeebe:input source="=&#34;PRIORITY_10&#34;" target="humanTaskPriorityCL" />
          <zeebe:input source="=[&#10;  &#10;  {&#10;    humanTaskEntityRelationshipTypeCL : &#34;BELONGING&#34;,&#10;    entityCL : &#34;CaseActivity&#34;,&#10;    entityId : entityId&#10;  },&#10;  {&#10;    humanTaskEntityRelationshipTypeCL : &#34;BELONGING&#34;,&#10;    entityCL : &#34;ProcessInstance&#34;,&#10;    entityId : processInstanceId&#10;  }&#10;]" target="relatedEntities" />
          <zeebe:input source="=&#34;Zeebe created for entityId:&#34; + entityId + &#34; and entityTypeId: &#34; + entityTypeId" target="comment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_16q2o5a</bpmn:incoming>
      <bpmn:outgoing>Flow_0u25dzr</bpmn:outgoing>
