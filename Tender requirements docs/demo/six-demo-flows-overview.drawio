          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow56" parent="1" source="f5" target="f6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#94A3B8;endArrow=open;endFill=0;strokeWidth=1.5;" edge="1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="workspace_band" parent="1" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=1.5;fontSize=14;fontStyle=1;fontColor=#334155;" value="Workspace Coverage" vertex="1">
          <mxGeometry x="180" y="796" width="1294" height="176" as="geometry" />
        </mxCell>
        <mxCell id="case_ws" parent="1" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#93C5FD;strokeWidth=1.5;fontSize=13;fontStyle=1;fontColor=#1D4ED8;" value="Case Worker Workspace&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Flows 2, 3, 4&lt;br&gt;Agent worklist in Flow 1&lt;/span&gt;" vertex="1">
          <mxGeometry x="224" y="844" width="360" height="82" as="geometry" />
        </mxCell>
        <mxCell id="ops_ws" parent="1" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#86EFAC;strokeWidth=1.5;fontSize=13;fontStyle=1;fontColor=#15803D;" value="Operations Workspace&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Flows 1, 3, 6&lt;br&gt;Dashboards, exception queues, third-party collection reporting&lt;/span&gt;" vertex="1">
          <mxGeometry x="646" y="844" width="360" height="82" as="geometry" />
        </mxCell>
        <mxCell id="config_ws" parent="1" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#FDBA74;strokeWidth=1.5;fontSize=13;fontStyle=1;fontColor=#C2410C;" value="Configuration Workspace&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Flow 5&lt;br&gt;Strategy, simulation, approval, versioning&lt;/span&gt;" vertex="1">
          <mxGeometry x="1068" y="844" width="360" height="82" as="geometry" />
        </mxCell>

        <mxCell id="bottom_note" parent="1" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;fontSize=13;fontStyle=1;fontColor=#334155;" value="Demo narrative: start with intake automation, prove safe customer handling, show escalation and complexity, then close with business-led change and real-time operational control." vertex="1">
          <mxGeometry x="180" y="1008" width="1294" height="54" as="geometry" />
        </mxCell>

