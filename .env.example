# Port the application listens on (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Spring profile: local | dev (default: local)
SPRING_PROFILES_ACTIVE=local

# PostgreSQL connection string
DATABASE_URL=postgresql://dcms:dcms@localhost:5432/dcms

# Keycloak configuration
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/dcms
KEYCLOAK_CLIENT_ID=dcms-backend
KEYCLOAK_CLIENT_SECRET=dcms-backend-secret

# Frontend Keycloak configuration (used by nginx / build)
VITE_KEYCLOAK_URL=http://localhost:9090
VITE_KEYCLOAK_REALM=dcms
VITE_KEYCLOAK_CLIENT_ID=dcms-frontend
