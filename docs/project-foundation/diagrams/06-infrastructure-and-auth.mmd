    BE_L -->|OIDC token validation| KC_L
  end

  subgraph DEV["Dev environment  (AKS on Azure — Helm chart)"]
    direction LR
    FE_D["Frontend pod\nnginx:1.27-alpine"]
    BE_D["Backend pod\neclipse-temurin:21-jre-jammy"]
    DB_D[("PostgreSQL 16")]
    KC_D["Keycloak 24"]
    FE_D -->|REST| BE_D
    BE_D --> DB_D
    BE_D -->|OIDC token validation| KC_D
  end

  subgraph CICD["CI/CD  (GitHub Actions)"]
    direction LR
    BUILD["Build & test\n(Maven + npm)"]
    SCAN["Container scan\nHelm lint"]
    PUSH["Push image\nufstpit-dev-docker.repo.netcompany.com\ndcms_v0/dcms_v0-{service}:{sha}"]
    DEPLOY_D["Deploy to dev\nHelm upgrade"]
    BUILD --> SCAN --> PUSH --> DEPLOY_D
  end

  subgraph AUTH["Auth flow (same in both environments — STD-PLAT-008)"]
    direction LR
    BROWSER["Browser / DWP Agent"]
    A1["1. Login redirect to Keycloak"]
    A2["2. Keycloak issues JWT\n(contains RBAC roles in claims)"]
    A3["3. Frontend sends JWT\nin Authorization header"]
    A4["4. Spring Security OAuth2\nResource Server validates JWT\nand enforces RBAC"]
    BROWSER --> A1 --> A2 --> A3 --> A4
  end

  PARITY["⚖ Parity rule (STD-PLAT-008)\nLocal and dev must be functionally equivalent:\nsame config keys · same auth flow (Keycloak never skipped)\nsame JSON log format\nAll divergences documented in remote-environment-spec.md"]

