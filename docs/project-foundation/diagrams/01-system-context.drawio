        <mxCell id="100" value="DWP Agent&#xa;Reviews candidate debts, manages cases, arranges repayments, handles communications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#5e97f6;fontColor=#0d47a1;fontSize=15;arcSize=10;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
