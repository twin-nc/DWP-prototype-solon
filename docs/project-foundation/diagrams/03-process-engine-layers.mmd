---
title: "DCMS — Process Engine Layering (ADR-003)"
---
flowchart TB
  subgraph DOMAIN["Domain modules  (no Flowable imports)"]
    direction LR
    H1["SendLetterCommandHandler\n(communications)"]
    H2["AssessAffordabilityCommandHandler\n(repaymentplan)"]
    H3["PostPaymentDeductionCommandHandler\n(payment)"]
    H4["TriggerSegmentationCommandHandler\n(strategy)"]
    H5["CreateWorkItemCommandHandler\n(workallocation)"]
    H6["RecordAccountNoteCommandHandler\n(account)"]
  end

  subgraph PORT["shared/process/port  (interfaces only — no Flowable)"]
    BUS["DelegateCommandBus\nroutes DelegateCommand\nto registered handlers"]
    PEP["ProcessEventPort\nfireMessage(debtAccountId, name, vars)\nfireSignal(customerId, name, vars)"]
    PSP["ProcessStartPort\nstartTreatment(debtAccountId, segmentCode)"]
  end

  subgraph INFRA["infrastructure/process  (only layer that imports Flowable)"]
    direction LR
    DEL["JavaDelegate implementations\nRead DelegateExecution variables\nConstruct command → dispatch via bus\n\ne.g. sendLetterDelegate\npostPaymentDeductionDelegate\ntriggerSegmentationDelegate"]
    FLOW["Flowable BPMN/DMN Engine\nRuntimeService · TaskService\nRepositoryService · HistoryService"]
    BPMN["BPMN process definitions\nresources/processes/\n  treatments/\n  fragments/\n  decisions/"]
  end

  DOMAIN -->|"implements handlers for\nowned command types"| BUS
  BUS -->|"routes command\nto handler"| DOMAIN
  DEL -->|"dispatch(command)"| BUS
  FLOW -->|"calls delegate\nvia bean name expression"| DEL
  BPMN -->|"deployed into"| FLOW
  PEP -->|"implemented by\nProcessEventPortImpl"| FLOW
  PSP -->|"implemented by\nProcessStartPortImpl"| FLOW

  note1["Domain modules call ProcessEventPort\nor ProcessStartPort — never RuntimeService directly"]

  style note1 fill:#fff8e1,stroke:#f9a825,color:#5d4037
