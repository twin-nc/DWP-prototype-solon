        <!-- Layer 2: Shared port -->
        <mxCell id="port_layer" value="Layer 2 — shared/process/port  (interfaces only — no Flowable)" style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="1560" height="180" as="geometry" />
        </mxCell>

        <mxCell id="bus" value="&lt;b&gt;DelegateCommandBus&lt;/b&gt;&lt;br&gt;&lt;br&gt;Routes DelegateCommand&lt;br&gt;to registered handler&lt;br&gt;&lt;br&gt;void dispatch(DelegateCommand cmd)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="port_layer">
          <mxGeometry x="380" y="40" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="pep" value="&lt;b&gt;ProcessEventPort&lt;/b&gt;&lt;br&gt;&lt;br&gt;fireMessage(debtAccountId, name, vars)&lt;br&gt;fireSignal(customerId, name, vars)&lt;br&gt;&lt;br&gt;Only way domain modules fire events into running process instances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="port_layer">
          <mxGeometry x="760" y="40" width="340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="psp" value="&lt;b&gt;ProcessStartPort&lt;/b&gt;&lt;br&gt;&lt;br&gt;startTreatment(debtAccountId, segmentCode)&lt;br&gt;&lt;br&gt;Only way a treatment process is started or restarted after resegmentation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="port_layer">
          <mxGeometry x="1110" y="40" width="340" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 3: Infrastructure/process -->
        <mxCell id="infra_layer" value="Layer 1 — infrastructure/process  (only layer that imports Flowable)" style="swimlane;startSize=35;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="1560" height="360" as="geometry" />
        </mxCell>

        <mxCell id="delegates" value="&lt;b&gt;JavaDelegate implementations&lt;/b&gt;&lt;br&gt;(infrastructure/process/delegate/)&lt;br&gt;&lt;br&gt;One delegate per BPMN service task action.&lt;br&gt;Reads DelegateExecution variables.&lt;br&gt;Constructs command → dispatch(cmd) via bus.&lt;br&gt;Zero domain module imports.&lt;br&gt;&lt;br&gt;e.g. sendLetterDelegate&lt;br&gt;     postPaymentDeductionDelegate&lt;br&gt;     triggerSegmentationDelegate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="infra_layer">
          <mxGeometry x="20" y="45" width="380" height="290" as="geometry" />
        </mxCell>

        <mxCell id="flowable_engine" value="&lt;b&gt;Flowable BPMN/DMN Engine&lt;/b&gt;&lt;br&gt;&lt;br&gt;RuntimeService&lt;br&gt;TaskService&lt;br&gt;RepositoryService&lt;br&gt;HistoryService&lt;br&gt;&lt;br&gt;Calls delegates via Spring bean name expression:&lt;br&gt;flowable:delegateExpression=&quot;${sendLetterDelegate}&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="infra_layer">
          <mxGeometry x="480" y="45" width="380" height="290" as="geometry" />
        </mxCell>

        <mxCell id="bpmn_res" value="&lt;b&gt;BPMN / DMN resources&lt;/b&gt;&lt;br&gt;(backend/src/main/resources/processes/)&lt;br&gt;&lt;br&gt;treatments/&lt;br&gt;&lt;i&gt;  treatment-vulnerable-on-benefit.bpmn&lt;/i&gt;&lt;br&gt;&lt;i&gt;  treatment-standard-on-benefit.bpmn&lt;/i&gt;&lt;br&gt;&lt;i&gt;  treatment-vulnerable-off-benefit.bpmn&lt;/i&gt;&lt;br&gt;&lt;i&gt;  treatment-standard-off-benefit.bpmn&lt;/i&gt;&lt;br&gt;&lt;br&gt;fragments/&lt;br&gt;&lt;i&gt;  standard-event-subprocesses.bpmn&lt;/i&gt;&lt;br&gt;&lt;br&gt;decisions/&lt;br&gt;&lt;i&gt;  segmentation.dmn&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="infra_layer">
          <mxGeometry x="940" y="45" width="380" height="290" as="geometry" />
        </mxCell>

        <mxCell id="port_impls" value="&lt;b&gt;Port implementations&lt;/b&gt;&lt;br&gt;(infrastructure/process/port/impl/)&lt;br&gt;&lt;br&gt;ProcessEventPortImpl&lt;br&gt;  → wraps RuntimeService.messageEventReceived()&lt;br&gt;  → wraps RuntimeService.signalEventReceived()&lt;br&gt;&lt;br&gt;ProcessStartPortImpl&lt;br&gt;  → wraps RuntimeService.startProcessInstanceByKey()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="infra_layer">
          <mxGeometry x="1330" y="45" width="200" height="290" as="geometry" />
        </mxCell>

