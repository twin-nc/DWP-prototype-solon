        <mxCell id="h5" value="&lt;b&gt;CreateWorkItemCommandHandler&lt;/b&gt;&lt;br&gt;(workallocation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="domain_layer">
