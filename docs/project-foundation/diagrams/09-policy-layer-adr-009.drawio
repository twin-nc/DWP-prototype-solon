        <mxCell id="cr1" value="&lt;b&gt;Mechanism 1&lt;/b&gt;&lt;br&gt;Dimensional Precedence&lt;br&gt;(automatic)&lt;br&gt;&lt;br&gt;Regulatory &gt; Customer Protection&lt;br&gt;&gt; Enforcement &gt; Debt Classification&lt;br&gt;&gt; Recovery Mechanics &gt; Operational" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="conflict_bg">
          <mxGeometry x="20" y="45" width="340" height="115" as="geometry" />
        </mxCell>

        <mxCell id="cr2" value="&lt;b&gt;Mechanism 2&lt;/b&gt;&lt;br&gt;Explicit Conflict Rule&lt;br&gt;(for arithmetic conflicts)&lt;br&gt;&lt;br&gt;e.g. two policies both set&lt;br&gt;a deduction rate — admin&lt;br&gt;declares TAKE_LOWER / TAKE_HIGHER&lt;br&gt;/ ESCALATE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="conflict_bg">
          <mxGeometry x="420" y="45" width="340" height="115" as="geometry" />
        </mxCell>

        <mxCell id="cr3" value="&lt;b&gt;Mechanism 3&lt;/b&gt;&lt;br&gt;No explicit rule → ESCALATE&lt;br&gt;(supervisor decision)&lt;br&gt;&lt;br&gt;System raises a supervisor&lt;br&gt;task rather than making&lt;br&gt;an automated call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="conflict_bg">
          <mxGeometry x="820" y="45" width="340" height="115" as="geometry" />
