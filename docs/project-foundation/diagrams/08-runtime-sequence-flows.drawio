        <mxCell id="s3note" value="Timer-driven behavior stays inside BPMN orchestration; domain handlers execute policy and persistence." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;" vertex="1" parent="s3">
