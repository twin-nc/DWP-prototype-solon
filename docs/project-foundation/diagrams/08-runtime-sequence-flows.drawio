<mxfile host="app.diagrams.net" modified="2026-04-23T00:00:00.000Z" agent="Codex" version="24.7.17" editor="draw.io" compressed="false">
  <diagram name="Runtime Sequence Flows">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="DCMS Runtime Sequence Flows (Clean Operational View)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="1960" height="40" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="Each lane shows one end-to-end flow. Arrows are routed left-to-right in numbered order for readability." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="60" width="1960" height="24" as="geometry" />
        </mxCell>

        <!-- Scenario 1 -->
        <mxCell id="s1" value="Flow 1: Case initiation (atomic create + process start)" style="swimlane;startSize=34;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="2100" height="255" as="geometry" />
        </mxCell>

        <mxCell id="s1n1" value="1. Agent promotes candidate&#xa;(frontend -> integration API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="20" y="62" width="240" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n2" value="2. Create/verify Customer&#xa;and create DebtAccount&#xa;inside one transaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="290" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n3" value="3. Strategy evaluates&#xa;segment via DMN/config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="570" y="62" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n4" value="4. ProcessStartPort&#xa;.startTreatment(debtAccountId, segmentCode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="820" y="62" width="290" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n5" value="5. Flowable starts process instance&#xa;(one instance per DebtAccount)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="1140" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n6" value="6. Service tasks call delegates&#xa;-> command bus -> handlers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="1420" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n7" value="7. Domain modules persist&#xa;ledger/comms/work/audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="1700" y="62" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s1n8" value="8. Case view updates&#xa;for agent/supervisor UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="s1">
          <mxGeometry x="1940" y="62" width="140" height="85" as="geometry" />
        </mxCell>

        <mxCell id="s1e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n1" target="s1n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n2" target="s1n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n3" target="s1n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n4" target="s1n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n5" target="s1n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n6" target="s1n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s1" source="s1n7" target="s1n8"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="s1note" value="If step 4 or 5 fails, the initiation transaction rolls back." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;" vertex="1" parent="s1">
          <mxGeometry x="20" y="170" width="800" height="24" as="geometry" />
        </mxCell>

        <!-- Scenario 2 -->
        <mxCell id="s2" value="Flow 2: Benefit ceased event (interrupt + resegment)" style="swimlane;startSize=34;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="385" width="2100" height="255" as="geometry" />
        </mxCell>

        <mxCell id="s2n1" value="1. DWP source sends&#xa;BENEFIT_CEASED update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="20" y="62" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n2" value="2. Integration validates payload&#xa;and idempotency key/reference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="270" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n3" value="3. ProcessEventPort.fireMessage&#xa;(debtAccountId, BENEFIT_CEASED, vars)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="550" y="62" width="300" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n4" value="4. Flowable interrupting event&#xa;subprocess catches event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="880" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n5" value="5. Current lane ends;&#xa;workflow triggers RESEGMENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="1160" y="62" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n6" value="6. Strategy returns new&#xa;segment code (DMN/rules)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="1420" y="62" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n7" value="7. ProcessStartPort starts&#xa;new treatment definition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="1680" y="62" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s2n8" value="8. Delegates/handlers update&#xa;work, comms, audit and UI state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="s2">
          <mxGeometry x="1940" y="62" width="140" height="85" as="geometry" />
        </mxCell>

        <mxCell id="s2e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n1" target="s2n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n2" target="s2n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n3" target="s2n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n4" target="s2n5"><mxGeometry relative="1" as="geometry" /></mxCell>
