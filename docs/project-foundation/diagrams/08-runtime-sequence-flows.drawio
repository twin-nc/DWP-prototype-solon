        <mxCell id="s2e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n6" target="s2n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="s2" source="s2n7" target="s2n8"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="s2note" value="Correlation key for BENEFIT_CEASED is debtAccountId. Message names are versioned contracts." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;" vertex="1" parent="s2">
          <mxGeometry x="20" y="170" width="980" height="24" as="geometry" />
        </mxCell>

        <!-- Scenario 3 -->
        <mxCell id="s3" value="Flow 3: Payment missed timer (breach handling)" style="swimlane;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="670" width="2100" height="255" as="geometry" />
        </mxCell>

        <mxCell id="s3n1" value="1. Payment timer reaches due threshold&#xa;inside active process instance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="20" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n2" value="2. Non-interrupting event&#xa;subprocess starts breach path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="300" y="62" width="240" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n3" value="3. Delegate dispatches&#xa;CreateWorkItemCommand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="570" y="62" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n4" value="4. Workallocation handler creates&#xa;queue item for agent action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="820" y="62" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n5" value="5. Communications handler sends&#xa;reminder based on policy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="1100" y="62" width="240" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n6" value="6. Repayment/payment logic evaluates&#xa;tolerance and next action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="1370" y="62" width="260" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n7" value="7. Account + audit persist&#xa;breach facts and decisions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="1660" y="62" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="s3n8" value="8. Queue and case state refresh&#xa;in agent/supervisor UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="s3">
          <mxGeometry x="1920" y="62" width="160" height="85" as="geometry" />
        </mxCell>

