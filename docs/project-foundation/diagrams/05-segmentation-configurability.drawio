  <diagram name="Segmentation and Configurability">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="DCMS — Segmentation &amp; Configurability (ADR-004)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="327" y="20" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- ===== LEFT: INPUTS ===== -->
        <mxCell id="inputs_bg" value="Account Inputs" style="swimlane;startSize=35;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="280" height="480" as="geometry" />
        </mxCell>

        <mxCell id="vuln" value="&lt;b&gt;Vulnerability flag&lt;/b&gt;&lt;br&gt;customer.vulnerabilityFlag&lt;br&gt;&lt;br&gt;Set by agent or auto-detected&lt;br&gt;from circumstances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="inputs_bg">
          <mxGeometry x="20" y="50" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="benefit" value="&lt;b&gt;Benefit status&lt;/b&gt;&lt;br&gt;account.onBenefit&lt;br&gt;&lt;br&gt;Whether debtor currently&lt;br&gt;receives DWP benefit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="inputs_bg">
          <mxGeometry x="20" y="160" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="debt_type" value="&lt;b&gt;Debt type / amount&lt;/b&gt;&lt;br&gt;account.debtType&lt;br&gt;account.totalBalance&lt;br&gt;&lt;br&gt;Used by DMN for further&lt;br&gt;sub-segmentation (Tier 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="inputs_bg">
          <mxGeometry x="20" y="270" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="history" value="&lt;b&gt;Payment history&lt;/b&gt;&lt;br&gt;account payment events&lt;br&gt;&lt;br&gt;Missed payments, prior&lt;br&gt;arrangement breaches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="inputs_bg">
          <mxGeometry x="20" y="385" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- ===== CENTRE: DMN ENGINE ===== -->
        <mxCell id="dmn_bg" value="Segmentation Engine  (DMN + Spring)" style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="400" height="480" as="geometry" />
        </mxCell>

        <mxCell id="dmn_table" value="&lt;b&gt;segmentation.dmn&lt;/b&gt;&lt;br&gt;(resources/processes/decisions/)&lt;br&gt;&lt;br&gt;Decision table evaluated by&lt;br&gt;Flowable DMN engine.&lt;br&gt;&lt;br&gt;Input columns:&lt;br&gt;• vulnerabilityFlag&lt;br&gt;• onBenefit&lt;br&gt;• debtType&lt;br&gt;• totalBalance&lt;br&gt;• missedPaymentCount&lt;br&gt;&lt;br&gt;Output:&lt;br&gt;• segmentCode (string)&lt;br&gt;• treatmentProcessKey (string)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="dmn_bg">
          <mxGeometry x="20" y="50" width="360" height="260" as="geometry" />
        </mxCell>

        <mxCell id="trigger_seg" value="&lt;b&gt;TriggerSegmentationCommandHandler&lt;/b&gt;&lt;br&gt;(strategy module)&lt;br&gt;&lt;br&gt;Evaluates DMN → resolves segmentCode&lt;br&gt;→ dispatches via ProcessStartPort&lt;br&gt;or re-routes running process via&lt;br&gt;ProcessEventPort" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="dmn_bg">
          <mxGeometry x="20" y="330" width="360" height="130" as="geometry" />
        </mxCell>

        <!-- ===== RIGHT: SEGMENTS ===== -->
        <mxCell id="segs_bg" value="Treatment Segments  (ADR-004)" style="swimlane;startSize=35;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="80" width="380" height="480" as="geometry" />
        </mxCell>

        <mxCell id="seg_vob" value="&lt;b&gt;VULNERABLE_ON_BENEFIT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Treatment: treatment-vulnerable-on-benefit.bpmn&lt;br&gt;&lt;br&gt;Extended contact attempts&lt;br&gt;Affordability-first approach&lt;br&gt;Enhanced vulnerability checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="segs_bg">
          <mxGeometry x="20" y="50" width="340" height="90" as="geometry" />
        </mxCell>

        <mxCell id="seg_voff" value="&lt;b&gt;VULNERABLE_OFF_BENEFIT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Treatment: treatment-vulnerable-off-benefit.bpmn&lt;br&gt;&lt;br&gt;Structured repayment plan&lt;br&gt;Vulnerability-aware contact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="segs_bg">
          <mxGeometry x="20" y="160" width="340" height="80" as="geometry" />
        </mxCell>

        <mxCell id="seg_sob" value="&lt;b&gt;STANDARD_ON_BENEFIT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Treatment: treatment-standard-on-benefit.bpmn&lt;br&gt;&lt;br&gt;Benefit deduction pathway&lt;br&gt;Standard contact cycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="segs_bg">
          <mxGeometry x="20" y="260" width="340" height="80" as="geometry" />
        </mxCell>

        <mxCell id="seg_soff" value="&lt;b&gt;STANDARD_OFF_BENEFIT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Treatment: treatment-standard-off-benefit.bpmn&lt;br&gt;&lt;br&gt;Full recovery pathway&lt;br&gt;Enforcement escalation available" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="segs_bg">
          <mxGeometry x="20" y="360" width="340" height="80" as="geometry" />
        </mxCell>

        <!-- ===== BOTTOM: EXCEPTION STATES ===== -->
        <mxCell id="except_bg" value="Exception States  (BPMN process states, NOT segments)" style="swimlane;startSize=35;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="1190" height="160" as="geometry" />
        </mxCell>

        <mxCell id="exc_bs" value="&lt;b&gt;BREATHING_SPACE&lt;/b&gt;&lt;br&gt;Moratorium — all activity paused&lt;br&gt;Timer-driven auto-resume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="except_bg">
          <mxGeometry x="20" y="45" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="exc_ins" value="&lt;b&gt;INSOLVENCY&lt;/b&gt;&lt;br&gt;Treatment suspended&lt;br&gt;Recovery only via insolvency process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="except_bg">
          <mxGeometry x="240" y="45" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="exc_dec" value="&lt;b&gt;DECEASED&lt;/b&gt;&lt;br&gt;All contact suppressed&lt;br&gt;Estate claim process only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="except_bg">
          <mxGeometry x="460" y="45" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="exc_fraud" value="&lt;b&gt;FRAUD_MARKER&lt;/b&gt;&lt;br&gt;Specialist team handoff&lt;br&gt;Investigation workflow only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="except_bg">
          <mxGeometry x="680" y="45" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="exc_note" value="⚠  These are BPMN process states, not segmentation outputs. They are handled by event subprocesses at root scope (ADR-002) and override normal treatment flow. They are NOT outputs of the DMN table." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="except_bg">
          <mxGeometry x="900" y="45" width="270" height="90" as="geometry" />
        </mxCell>

        <!-- ===== BOTTOM: CONFIGURABILITY TIERS ===== -->
        <mxCell id="tiers_bg" value="Two-Tier Configurability Model  (ADR-004)" style="swimlane;startSize=35;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="1190" height="200" as="geometry" />
        </mxCell>

        <mxCell id="tier1" value="&lt;b&gt;Tier 1 — No-code (DMN + DB)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ops Manager can edit the DMN decision table&lt;br&gt;via the Flowable Admin UI (no deployment needed).&lt;br&gt;&lt;br&gt;Also: rule parameters in DB (thresholds, letter templates,&lt;br&gt;retry counts) editable at runtime without restart.&lt;br&gt;&lt;br&gt;&lt;i&gt;Examples: adjust affordability threshold, add debt sub-type rule&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="tiers_bg">
          <mxGeometry x="20" y="45" width="560" height="135" as="geometry" />
        </mxCell>

        <mxCell id="tier2" value="&lt;b&gt;Tier 2 — Low-code (Runtime BPMN deployment)&lt;/b&gt;&lt;br&gt;&lt;br&gt;New treatment process variants can be deployed as&lt;br&gt;BPMN definitions at runtime via Flowable RepositoryService.&lt;br&gt;&lt;br&gt;Follows BPMN versioning policy (ADR-006):&lt;br&gt;• Non-breaking → deploy-and-monitor&lt;br&gt;• Breaking/bug-fix → named migration script + force-migrate&lt;br&gt;&lt;br&gt;&lt;i&gt;Examples: new segment variant, champion/challenger test treatment&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="tiers_bg">
          <mxGeometry x="610" y="45" width="560" height="135" as="geometry" />
        </mxCell>

        <!-- ===== ARROWS: inputs → dmn ===== -->
        <mxCell id="a1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="vuln" target="dmn_table" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="benefit" target="dmn_table" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="debt_type" target="dmn_table" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="history" target="dmn_table" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- dmn_table → trigger_seg (internal) -->
        <mxCell id="a5" value="segmentCode" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="dmn_table" target="trigger_seg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- trigger_seg → segments -->
        <mxCell id="a6" value="startTreatment()" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="trigger_seg" target="seg_vob" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="trigger_seg" target="seg_voff" parent="1">
