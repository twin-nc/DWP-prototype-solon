        <mxCell id="230b" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontStyle=2;fontColor=#82b366;" value="incl. Foundations Configurator" vertex="1">
          <mxGeometry height="14" width="220" x="1217" y="117" as="geometry" />
        </mxCell>
        <mxCell id="231" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;" value="&lt;font style=&quot;font-size:11px;&quot;&gt;• Agent Desktop (delinquency view, ID&amp;V prompt, case timeline, quick actions, flash notes on vulnerability)&lt;br&gt;• Supervisor Dashboard (real-time queue health, SLA status, agent utilisation, bulk reassign)&lt;br&gt;• MI &amp; Analytics (KPI tiles, strategy performance, DCA league table, C/C live results)&lt;br&gt;• Foundations Configurator (codelists, system params, RBAC, templates, queue config — wraps Solon reference data + Keycloak)&lt;br&gt;• Self-Service Portal Extensions (debt summary, payment, I&amp;E, dispute initiation — extends Solon Self-Service Portal)&lt;/font&gt;" vertex="1">
          <mxGeometry height="175" width="365" x="1217" y="132" as="geometry" />
