        <mxCell id="workAlloc" value="&lt;b&gt;Work Allocation&#10;Service&lt;/b&gt;&#10;&#10;DWP queue rules · worklist composition&#10;Supervisor override · exception queue routing&#10;SLA timer enforcement · bulk reassign&#10;&#10;Reads Solon Human Task Management&#10;Issues task assignment commands" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
