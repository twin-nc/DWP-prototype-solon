        <!-- =====================================================
             LAYER 8 — STORAGE
             ===================================================== -->
        <mxCell id="db" value="PostgreSQL 16  ·  TWO schemas:  solon (Solon-owned, Liquibase by Solon)  +  dcms (DCMS-owned, Liquibase contexts scoped to dcms)  ·  same instance  ·  data classification drives at-rest encryption (Restricted = field-level KMS key) + audit obligations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#B22222;dashed=1;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1276" width="1820" height="46" as="geometry" />
        </mxCell>

        <!-- Internal Kafka warning -->
        <mxCell id="kafkaWarning" value="⚠  irm.bpmn-engine.*  INTERNAL Kafka topics — DCMS layer must NOT publish to these. Use only documented external command catalogue (Blocker 1). DCMS observes Solon event stream as consumer only via consumer-group isolation." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#B22222;strokeColor=#B22222;fontColor=#ffffff;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1330" width="1820" height="28" as="geometry" />
        </mxCell>

        <!-- =====================================================
             ANNOTATION CALLOUTS
             ===================================================== -->

        <!-- Six demo flows in focus -->
        <mxCell id="sixFlows" value="&lt;b&gt;★ SIX DEMO FLOWS IN FOCUS  (Release 1 subset of the full 14)&lt;/b&gt;&#10;&#10;Flow 1  Account Intake → First Meaningful Contact&#10;        Operations BFF dashboard · Case Worker BFF worklist&#10;Flow 2  Vulnerability → Resolution&#10;        VulnGov direct call · BS-Gate · C/C immediate reassign&#10;Flow 3  Arrangement Breach → DCA Placement&#10;        Arrangement BPMN · Comms-Suppr · DCA Placement Svc&#10;Flow 4  Complex Household — Joint Liability, Competing Workflows&#10;        Household BPMN · Person-level BS-Gate read · Customer master&#10;Flow 5  Strategy Change Without IT&#10;        Configuration SPA + BFF · Strategy Authoring Svc · approval&#10;        pipeline · simulation · live-impact projection in Operations&#10;Flow 6  Executive / Operational Dashboard — Real-Time Oversight&#10;        Operations BFF projections from event stream · drill-down" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=2;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="1370" width="540" height="245" as="geometry" />
        </mxCell>

        <!-- C3 inherited callout -->
        <mxCell id="c3Callout" value="&lt;b&gt;⚠ INHERITED — C3  suspendActiveInstancesSW vs RULING-016&lt;/b&gt;&#10;&#10;Per Option B condition (Solon platform expert review,&#10;2026-05-01): set FALSE for ALL DCMS SuppressionTypes&#10;(standard BS, MHCM, Vulnerability, internal policy holds).&#10;&#10;Effect: 100% of effect-suppression sits on&#10;BreathingSpaceGatingService (gate-at-effect model).&#10;Solon records suppression as metadata only.&#10;&#10;Reconciliation with RULING-016 must be SA-declared&#10;before lock — not deferable to detailed design." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#B22222;dashed=1;strokeWidth=3;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="1370" width="430" height="245" as="geometry" />
        </mxCell>

        <!-- Inherited blockers -->
        <mxCell id="blockers" value="&lt;b&gt;⛔ INHERITED BLOCKERS — gate this design's lock&lt;/b&gt;&#10;&#10;Blocker 1  Kafka command-name discrepancy. Abstracted&#10;commands (PostPaymentCommand etc.) not confirmed as&#10;externally-publishable Kafka topics. If not, Option B&#10;contract collapses → fallback to irm.bpmn-engine.*&#10;(tighter coupling) or sync REST (Blocker 2 territory).&#10;Verify as complete contract: names, schemas, response&#10;events, consumer-group isolation.&#10;&#10;Blocker 2  Solon REST API stability. Three BFFs all&#10;depend on stable sync queries (balance, suppressions,&#10;task state). Stability guarantees not documented.&#10;&#10;Blocker 3  SuppressionExpiryJob behaviour with&#10;maximumNumberDays=0 for MHCM AND Vulnerability types.&#10;Wrong interpretation auto-expires MHCM without sign-off&#10;= breach Reg 21 Debt Respite Scheme Regs 2020&#10;(criminal liability). Verify by test." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#B22222;dashed=1;strokeWidth=3;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1050" y="1370" width="430" height="245" as="geometry" />
        </mxCell>

        <!-- Amplio constraints + Java -->
        <mxCell id="amplioConstraints" value="&lt;b&gt;Amplio Constraints (carried forward)&lt;/b&gt;&#10;&#10;• Parallel Gateway: sequential-only&#10;• Script Tasks: FEEL-only&#10;• Business Rule Tasks → Service Tasks → Drools KIE&#10;• Compensation events: not implemented&#10;• Two SuppressionType configs (standard + MHCM)&#10;• Only integration-guide §5 Kafka topics (Blocker 1)&#10;&#10;&lt;b&gt;Java Version&lt;/b&gt; — Solon Java 17 baseline.&#10;Java 25 GA (forward-looking) would dissolve&#10;the Lever-1 flip-to-C condition." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1500" y="1370" width="360" height="245" as="geometry" />
        </mxCell>

