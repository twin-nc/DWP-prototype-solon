        <mxCell id="vuln" value="&lt;b&gt;Vulnerability&#10;Governance Service&lt;/b&gt;&#10;&#10;FCA FG21/1 tiers · MHCM compounding&#10;Identification triggers · evidence capture&#10;Review scheduling&#10;&#10;DIRECT in-process call from BPMN&#10;service tasks (no Data Area mirror)&#10;— RULING-010 'immediately' satisfied&#10;&#10;Schema: vulnerability_record&#10;Restricted classification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
