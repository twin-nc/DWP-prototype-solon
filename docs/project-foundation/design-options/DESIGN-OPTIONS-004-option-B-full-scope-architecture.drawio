        <mxCell id="outboxNote" value="&lt;b&gt;Outbox Pattern (mandatory)&lt;/b&gt;&#10;&#10;state-write + outbox row in&#10;same DB transaction&#10;dispatcher → Kafka, mark dispatched&#10;at-least-once delivery&#10;consumers dedupe on event id&#10;idempotency-key contract (AI 5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1538" y="952" width="300" height="115" as="geometry" />
