        <!-- Title -->
        <mxCell id="title" value="DESIGN-OPTIONS-004 · Option B at Full Scope — Three Workspaces · Three BFFs · Event-Driven · Solon-Backed&#10;All FRs / NFRs · All 14 demo flows (six Release-1 flows in focus) · Same JVM as Solon (Java 17) · DCMS BPMN / services / schema DCMS-owned" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="1820" height="50" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="LEGEND:  Green = Solon-owned    Blue = DCMS-owned    Amber = Shared / extension seam    Purple = Security overlay    Red dashed border = inherited blocker / open risk    Yellow callout = constraint / note" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1820" height="22" as="geometry" />
        </mxCell>

        <!-- =====================================================
             LAYER 1 — SHARED SHELL + THREE WORKSPACE SPAs
             ===================================================== -->
        <mxCell id="shellBand" value="SHARED PRODUCT SHELL  (micro-frontend host: Module Federation · single Keycloak session · cross-workspace notifications · RBAC-gated nav · shared design system)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="86" width="1820" height="170" as="geometry" />
        </mxCell>

        <mxCell id="spaCW" value="&lt;b&gt;Case Worker SPA&lt;/b&gt;&#10;Frontline runtime (NFR latency-critical)&#10;&#10;Flows 1, 2, 3, 4 (primary) · 7, 8, 9, 11, 14&#10;&#10;Case detail · ID&amp;V · Vulnerability panel · Guided&#10;scripting · I&amp;E · Arrangement capture · Notes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="580" height="125" as="geometry" />
        </mxCell>

        <mxCell id="spaOps" value="&lt;b&gt;Operations SPA&lt;/b&gt;&#10;Oversight + MI (NFR read-heavy)&#10;&#10;Flows 1, 6, 12, 13 (primary) · 3, 5, 10, 11, 14&#10;&#10;Live queue dashboards · SLA · C/C results · DCA&#10;perf · Audit/evidence viewer · Bulk reassign" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="120" width="580" height="125" as="geometry" />
        </mxCell>

        <mxCell id="spaCfg" value="&lt;b&gt;Configuration SPA&lt;/b&gt;&#10;Strategy + control (NFR write/audit-heavy)&#10;&#10;Flow 5 (primary) · 6, 12 (supporting)&#10;&#10;Strategy assembler · Drools rule builder · Task&#10;form designer · Policy bundles · Simulation · Versions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1260" y="120" width="580" height="125" as="geometry" />
        </mxCell>

        <!-- =====================================================
             LAYER 2 — BROWSER ⇄ BFF SECURITY EDGE
             ===================================================== -->
        <mxCell id="edgeSec" value="↕  Browser ⇄ BFF  ·  TLS 1.3  ·  OIDC + PKCE (Keycloak)  ·  short-lived access tokens (≤ 15 min)  ·  CSP / HSTS / SameSite cookies  ·  anti-CSRF on state-changing endpoints" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontColor=#4a148c;verticalAlign=middle;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="262" width="1820" height="26" as="geometry" />
        </mxCell>

        <!-- =====================================================
             LAYER 3 — THREE BFFs
             ===================================================== -->
        <mxCell id="bffBand" value="BFF LAYER  —  three independently deployable Backend-for-Frontend services  ·  per-workspace screen-shaped APIs  ·  per-workspace OPA policy bundles  ·  on-behalf-of token exchange to downstream  ·  read-model projections fed from event stream" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="294" width="1820" height="200" as="geometry" />
        </mxCell>

        <mxCell id="bffCW" value="&lt;b&gt;Case Worker BFF&lt;/b&gt;&#10;&#10;Composition · authz (OPA)&#10;Token exchange · idempotency keys&#10;&#10;Read-models:&#10;• Case timeline   (&lt; 2 s)&#10;• Worklist        (&lt; 5 s)&#10;• Notifications stream&#10;&#10;Sync to Solon: live ledger balance,&#10;active suppressions, task state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="328" width="580" height="155" as="geometry" />
        </mxCell>

        <mxCell id="bffOps" value="&lt;b&gt;Operations BFF&lt;/b&gt;&#10;&#10;Composition · authz (OPA)&#10;Token exchange · idempotency keys&#10;&#10;Read-models:&#10;• Live queue dashboard  (&lt; 5 s)&#10;• C/C results          (minute-scale)&#10;• DCA placement        (&lt; 30 s)&#10;• Audit-evidence view  (&lt; 10 s)&#10;&#10;Highest projection volume — scales independently" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="328" width="580" height="155" as="geometry" />
        </mxCell>

        <mxCell id="bffCfg" value="&lt;b&gt;Configuration BFF&lt;/b&gt;&#10;&#10;Composition · authz (OPA)&#10;Token exchange · idempotency keys&#10;&#10;Read-models:&#10;• Strategy version history (&lt; 5 s)&#10;• Simulation results        (on demand)&#10;&#10;Write-heavy / audit-heavy / lower QPS&#10;Approval pipeline integration · diff capture" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1260" y="328" width="580" height="155" as="geometry" />
        </mxCell>

        <!-- =====================================================
             LAYER 4 — BFF ⇄ CORE SERVICE SECURITY EDGE
             ===================================================== -->
        <mxCell id="meshSec" value="↕  BFF ⇄ Core Services / Solon  ·  service-mesh mTLS  ·  machine OAuth2 (on-behalf-of)  ·  OPA decision points at BFF + sensitive Core Service entry points  ·  distributed tracing with user identity propagated end-to-end" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontColor=#4a148c;verticalAlign=middle;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="1820" height="26" as="geometry" />
        </mxCell>

        <!-- =====================================================
             LAYER 5 — DCMS CUSTOM LAYER (CORE SERVICES)
             ===================================================== -->
        <mxCell id="dcmsBand" value="DCMS CUSTOM LAYER  —  revenue-management-be-custom (Spring beans, in-process with Solon, same JVM)  ·  DWP BPMN deployed into Solon's Amplio  ·  DCMS Drools KIE module · DCMS schema in shared PostgreSQL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="532" width="1820" height="380" as="geometry" />
        </mxCell>

        <mxCell id="c2Note" value="C2 caveat (inherited): in-process beans see the full Solon class graph. Containment of upgrade blast radius is a discipline claim, not architectural separation. Recommendation rests on domain-service ownership, not isolation." style="text;html=1;align=left;verticalAlign=middle;fontSize=9;fontColor=#B22222;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="552" width="1100" height="16" as="geometry" />
        </mxCell>

        <!-- Row 1: Gating, Vulnerability, C/C -->
        <mxCell id="bsGate" value="&lt;b&gt;Breathing Space&#10;Gating Service&lt;/b&gt;&#10;&#10;Gate-at-effect per RULING-016&#10;Reads Solon active_suppressions&#10;Returns PERMIT / SUPPRESS /&#10;DEFER_PENDING_MORATORIUM_END&#10;&#10;MHCM-specific logic · gated-effect&#10;catalogue (RULING-005/010/011/&#10;014/016) · arrangement-creation&#10;gate (RULING-014 g2)&#10;&#10;Schema: breathing_space_gate_log&#10;&#10;C3 contradiction live (see callout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#B22222;dashed=1;strokeWidth=2;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
