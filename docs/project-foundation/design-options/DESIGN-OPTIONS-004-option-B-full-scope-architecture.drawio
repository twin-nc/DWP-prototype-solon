             ===================================================== -->
        <mxCell id="eventBand" value="EVENT FABRIC  —  Kafka  ·  mTLS + SASL/OAUTHBEARER  ·  Schema Registry (additive-only)  ·  topic-level ACLs  ·  consumer-group isolation  ·  Outbox pattern at every state-writing service  ·  field-level encryption for Restricted payloads" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=11;" vertex="1" parent="1">
