        <mxCell id="title" value="Option B — Medium Custom Layer  ★ RECOMMENDED ★&#10;DCMS domain services orchestrate Solon primitives. Same JVM, but DCMS BPMN/services/schema are DCMS-owned." style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1320" height="50" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="LEGEND&#10;Green = Solon-owned    Blue = DCMS-owned    Amber = Shared/Extension seam    Red dashed = Distinguishing feature of this option" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1320" height="30" as="geometry" />
