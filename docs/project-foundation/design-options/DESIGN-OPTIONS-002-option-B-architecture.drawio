        <mxCell id="e_dcms_kafka" value="commands / events" style="endArrow=open;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" parent="1" source="dcmsBand" target="kafkaB">
