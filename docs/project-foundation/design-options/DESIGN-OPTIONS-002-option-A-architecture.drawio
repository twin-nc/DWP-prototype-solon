        <mxCell id="suppression" parent="solon" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#E65100;fontColor=#FFFFFF;fontSize=9;verticalAlign=top;align=left;strokeWidth=2;" value="&lt;b&gt;Suppression Module&lt;/b&gt;&#xa;&#xa;BREATHING_SPACE type:&#xa;  maxDays=60&#xa;  overrideEndDateSW=false&#xa;  → native 60-day enforcement&#xa;&#xa;MHCM type:&#xa;  maxDays=36500 (100yr — operational workaround)&#xa;  overrideEndDateSW=true&#xa;  → DCMS sets explicit end date via&#xa;    ReleaseSuppressionCommand&#xa;&#xa;⚠ Never set maxDays=0 on MHCM&#xa;  (ExpiryJob may treat 0 as already expired)" vertex="1">
