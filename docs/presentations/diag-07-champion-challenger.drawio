        <mxCell id="can-logic" parent="can-change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontSize=11;arcSize=6;spacing=6;align=left;spacingLeft=10;" value="&lt;b&gt;Treatment path assignment&lt;/b&gt;&lt;br/&gt;e.g. Champion routes &quot;low balance + employed&quot; to self-cure. Challenger tests light-touch phone outreach first." vertex="1">
