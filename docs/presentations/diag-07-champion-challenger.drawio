        <mxCell id="can-routing" parent="can-change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontSize=11;arcSize=6;spacing=6;align=left;spacingLeft=10;" value="&lt;b&gt;Routing outputs&lt;/b&gt;&lt;br/&gt;e.g. Champion routes debt category X to queue A. Challenger tests queue B for faster cycle time." vertex="1">
