        <mxCell id="footer" parent="1" style="text;html=1;fontSize=11;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#546E7A;" value="Key constraint: configuration can change business strategy without code deployment, but legal protections, approval evidence and in-flight determinism remain non-negotiable." vertex="1">
