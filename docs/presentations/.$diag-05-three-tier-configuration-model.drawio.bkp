        <mxCell id="freq-tier1" parent="workspace-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;fontStyle=1;arcSize=6;spacing=10;" value="Rare / as needed&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Stable vocabulary and reference definitions&lt;/font&gt;" vertex="1">
