  <diagram name="DIAG-04 Entity Model" id="diag-04">
    <mxGraphModel dx="1884" dy="961" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="932" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=22;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1A1A1A;" value="DIAG-04 - Entity Model: How a Debt Becomes an Account" vertex="1">
          <mxGeometry height="36" width="1060" x="297" y="22" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;fontSize=12;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#455A64;" value="Person-level protections and authority feed each account; each DebtAccount carries its own process instance and repayment arrangements." vertex="1">
          <mxGeometry height="24" width="1160" x="247" y="58" as="geometry" />
        </mxCell>

        <mxCell id="model-boundary" parent="1" style="swimlane;startSize=34;fillColor=#F7FAFC;strokeColor=#455A64;strokeWidth=3;fontColor=#263238;fontSize=14;fontStyle=1;arcSize=3;align=left;spacingLeft=12;" value="Simplified entity model - leadership view, not full physical schema" vertex="1">
          <mxGeometry height="650" width="1490" x="82" y="108" as="geometry" />
        </mxCell>

        <mxCell id="person" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;strokeColor=#263238;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=13;" value="&lt;b&gt;Person&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;One claimant or one member of a joint UC claim&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;- vulnerability flags&lt;br/&gt;- accessibility needs&lt;br/&gt;- third-party authority&lt;br/&gt;- joint liability participation&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Person-level data used before treatment, contact, disclosure or enforcement.&lt;/font&gt;" vertex="1">
          <mxGeometry height="310" width="345" x="52" y="86" as="geometry" />
        </mxCell>
        <mxCell id="link" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;strokeColor=#4A148C;fontColor=#FFFFFF;fontSize=12;arcSize=6;spacing=10;" value="&lt;b&gt;Account-Person Link&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Explicit liability relationship&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;Individual account: 1 Person&lt;br/&gt;Joint UC account: exactly 2 Persons&lt;br/&gt;Never household members" vertex="1">
          <mxGeometry height="188" width="230" x="457" y="147" as="geometry" />
        </mxCell>
        <mxCell id="account" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#283593;strokeColor=#1A237E;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=13;" value="&lt;b&gt;DebtAccount&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Recoverable unit and financial ledger&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;- breathing_space_flag&lt;br/&gt;- insolvency_date&lt;br/&gt;- deceased_flag&lt;br/&gt;- fraud_marker&lt;br/&gt;- flowable_process_instance_id&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Records regulatory facts for audit; Flowable owns lifecycle behaviour.&lt;/font&gt;" vertex="1">
          <mxGeometry height="330" width="390" x="747" y="76" as="geometry" />
        </mxCell>
        <mxCell id="arrangement" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=13;" value="&lt;b&gt;RepaymentArrangement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Plan agreed against one account&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;- terms&lt;br/&gt;- status&lt;br/&gt;- breach_threshold&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Arrangement monitoring pauses during breathing space; breach logic reads current account state.&lt;/font&gt;" vertex="1">
          <mxGeometry height="252" width="292" x="1172" y="115" as="geometry" />
        </mxCell>

        <mxCell id="flowable" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B71C1C;strokeColor=#7F0000;fontColor=#FFFFFF;fontSize=12;arcSize=6;spacing=11;" value="&lt;b&gt;Flowable Process Instance&lt;/b&gt;&lt;br/&gt;One long-running lifecycle process per DebtAccount&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Different accounts for the same Person can be at different lifecycle stages.&lt;/font&gt;" vertex="1">
          <mxGeometry height="105" width="390" x="747" y="466" as="geometry" />
        </mxCell>
        <mxCell id="case-view" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;fontColor=#5D4037;fontSize=12;arcSize=6;spacing=10;" value="&lt;b&gt;Case view&lt;/b&gt;&lt;br/&gt;Read-model aggregation across Person, DebtAccount, arrangements and process history.&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Not a separate lifecycle aggregate.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="345" x="52" y="461" as="geometry" />
        </mxCell>
        <mxCell id="guardrail" parent="model-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontColor=#B71C1C;fontSize=12;arcSize=6;spacing=10;" value="&lt;b&gt;Treatment guardrail&lt;/b&gt;&lt;br/&gt;Before contact, disclosure, deduction, legal referral or DCA placement, check the current regulatory status of every linked Person." vertex="1">
          <mxGeometry height="110" width="292" x="1172" y="461" as="geometry" />
        </mxCell>

