<mxfile host="Electron" agent="Codex">
  <diagram name="DIAG-03 Delegate Command Pattern" id="diag-03">
    <mxGraphModel dx="1884" dy="961" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="932" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=22;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1A1A1A;" value="DIAG-03 - Delegate Command Pattern  (ADR-003)" vertex="1">
          <mxGeometry height="36" width="980" x="337" y="22" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;fontSize=12;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#455A64;" value="Flowable is isolated behind shared ports. Domain modules never import Flowable types and process infrastructure never imports domain services directly." vertex="1">
          <mxGeometry height="24" width="1080" x="287" y="58" as="geometry" />
        </mxCell>
        <mxCell id="monolith-boundary" parent="1" style="swimlane;startSize=34;fillColor=#EEF4FF;strokeColor=#1565C0;strokeWidth=3;fontColor=#0D47A1;fontSize=14;fontStyle=1;arcSize=3;align=left;spacingLeft=12;" value="Backend Monolith - controlled process-engine boundary" vertex="1">
          <mxGeometry height="710" width="1190" x="232" y="100" as="geometry" />
        </mxCell>
        <mxCell id="domain-layer" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#283593;strokeColor=#1A237E;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=12;" value="&lt;b&gt;Domain modules&lt;/b&gt;&lt;br/&gt;account, communications, repaymentplan, payment, strategy, workallocation, thirdpartymanagement&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Own business invariants and command handlers. May depend on shared/process/port. Zero Flowable imports.&lt;/font&gt;" vertex="1">
          <mxGeometry height="112" width="1040" x="75" y="60" as="geometry" />
        </mxCell>
        <mxCell id="handler-chip" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A237E;strokeColor=#C5CAE9;strokeWidth=1;fontColor=#FFFFFF;fontSize=11;arcSize=10;spacing=8;" value="Command handlers&lt;br/&gt;plain Spring beans&lt;br/&gt;no DelegateExecution" vertex="1">
          <mxGeometry height="72" width="178" x="902" y="80" as="geometry" />
        </mxCell>
        <mxCell id="port-layer" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;strokeColor=#4A148C;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=12;" value="&lt;b&gt;shared / process / port&lt;/b&gt;&lt;br/&gt;ProcessEventPort | ProcessStartPort | DelegateCommandBus | DelegateCommand | DelegateCommandHandler&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Stable contract surface. Contains command types and port interfaces only. No Flowable dependency.&lt;/font&gt;" vertex="1">
          <mxGeometry height="112" width="1040" x="75" y="225" as="geometry" />
        </mxCell>
        <mxCell id="infra-layer" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#AD1457;strokeColor=#880E4F;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=12;" value="&lt;b&gt;infrastructure / process&lt;/b&gt;&lt;br/&gt;Flowable configuration | BPMN / DMN resources | JavaDelegate implementations | port implementations&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Only package allowed to import Flowable. Delegates create commands and dispatch through the bus.&lt;/font&gt;" vertex="1">
          <mxGeometry height="112" width="1040" x="75" y="390" as="geometry" />
        </mxCell>
        <mxCell id="delegate-chip" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#880E4F;strokeColor=#F8BBD0;strokeWidth=1;fontColor=#FFFFFF;fontSize=11;arcSize=10;spacing=8;" value="JavaDelegate beans&lt;br/&gt;read process vars&lt;br/&gt;dispatch commands" vertex="1">
          <mxGeometry height="72" width="178" x="902" y="410" as="geometry" />
        </mxCell>
        <mxCell id="flowable-layer" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B71C1C;strokeColor=#7F0000;fontColor=#FFFFFF;fontSize=13;arcSize=6;spacing=12;" value="&lt;b&gt;Flowable BPMN / DMN Engine&lt;/b&gt;&lt;br/&gt;Embedded engine executes process definitions, timers, user tasks, service tasks, and decisions&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Reached only through infrastructure/process. Engine APIs are not exposed to domain modules.&lt;/font&gt;" vertex="1">
          <mxGeometry height="96" width="1040" x="75" y="555" as="geometry" />
        </mxCell>
        <mxCell id="event-down-1" edge="1" parent="monolith-boundary" source="domain-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6A1B9A;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#4A148C;exitX=0.28;exitY=1;entryX=0.28;entryY=0;endArrow=block;endFill=1;" target="port-layer" value="domain fires process events / starts process">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="event-down-2" edge="1" parent="monolith-boundary" source="port-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#AD1457;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#880E4F;exitX=0.28;exitY=1;entryX=0.28;entryY=0;endArrow=block;endFill=1;" target="infra-layer" value="port implementation lives here">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="event-down-3" edge="1" parent="monolith-boundary" source="infra-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#B71C1C;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#7F0000;exitX=0.28;exitY=1;entryX=0.28;entryY=0;endArrow=block;endFill=1;" target="flowable-layer" value="RuntimeService / TaskService calls">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="delegate-up-1" edge="1" parent="monolith-boundary" source="flowable-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#B71C1C;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#7F0000;exitX=0.72;exitY=0;entryX=0.72;entryY=1;endArrow=block;endFill=1;" target="infra-layer" value="BPMN service task invokes delegateExpression">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="delegate-up-2" edge="1" parent="monolith-boundary" source="infra-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#AD1457;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#880E4F;exitX=0.72;exitY=0;entryX=0.72;entryY=1;endArrow=block;endFill=1;" target="port-layer" value="DelegateCommandBus.dispatch(command)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="delegate-up-3" edge="1" parent="monolith-boundary" source="port-layer" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6A1B9A;strokeWidth=3;fontSize=11;fontStyle=2;fontColor=#4A148C;exitX=0.72;exitY=0;entryX=0.72;entryY=1;endArrow=block;endFill=1;" target="domain-layer" value="routed to owning domain handler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="left-label" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontColor=#4A148C;fontSize=12;fontStyle=1;arcSize=6;spacing=8;" value="Domain-to-engine path&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;ProcessEventPort / ProcessStartPort&lt;/font&gt;" vertex="1">
          <mxGeometry height="58" width="245" x="31" y="335" as="geometry" />
        </mxCell>
        <mxCell id="right-label" parent="monolith-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=12;fontStyle=1;arcSize=6;spacing=8;" value="Engine-to-domain path&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;DelegateCommandBus and handlers&lt;/font&gt;" vertex="1">
          <mxGeometry height="58" width="245" x="934" y="337" as="geometry" />
        </mxCell>
        <mxCell id="prohibited-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontColor=#B71C1C;fontSize=12;arcSize=6;spacing=10;" value="&lt;b&gt;Prohibited coupling&lt;/b&gt;&lt;br/&gt;No domain module imports Flowable&lt;br/&gt;No domain code calls RuntimeService or TaskService&lt;br/&gt;No delegate autowires domain services directly" vertex="1">
          <mxGeometry height="138" width="215" x="32" y="298" as="geometry" />
        </mxCell>
        <mxCell id="prohibited-icon" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#B71C1C;strokeColor=#7F0000;fontColor=#FFFFFF;fontSize=28;fontStyle=1;" value="!" vertex="1">
          <mxGeometry height="44" width="44" x="116" y="244" as="geometry" />
        </mxCell>
        <mxCell id="contract-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=1;fontColor=#1A1A1A;fontSize=11;arcSize=5;spacing=10;" value="&lt;b&gt;Contract rule&lt;/b&gt;&lt;br/&gt;Each BPMN service-task action has:&lt;br/&gt;1. command type in shared/process/port&lt;br/&gt;2. delegate bean in infrastructure/process&lt;br/&gt;3. handler in the owning domain module&lt;br/&gt;&lt;br/&gt;Delegate bean names referenced by BPMN are stable contracts." vertex="1">
          <mxGeometry height="198" width="215" x="32" y="474" as="geometry" />
        </mxCell>
        <mxCell id="legend-bg" parent="1" style="rounded=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=1;arcSize=5;" value="" vertex="1">
          <mxGeometry height="181" width="190" x="1438" y="218" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" parent="1" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1A1A1A;" value="Legend" vertex="1">
          <mxGeometry height="20" width="70" x="1452" y="226" as="geometry" />
        </mxCell>
        <mxCell id="leg-dom" parent="1" style="rounded=1;fillColor=#283593;strokeColor=#1A237E;fontColor=#FFFFFF;fontSize=10;arcSize=20;" value="Domain module" vertex="1">
          <mxGeometry height="24" width="160" x="1452" y="252" as="geometry" />
        </mxCell>
        <mxCell id="leg-port" parent="1" style="rounded=1;fillColor=#6A1B9A;strokeColor=#4A148C;fontColor=#FFFFFF;fontSize=10;arcSize=20;" value="Port interface" vertex="1">
          <mxGeometry height="24" width="160" x="1452" y="282" as="geometry" />
        </mxCell>
        <mxCell id="leg-infra" parent="1" style="rounded=1;fillColor=#AD1457;strokeColor=#880E4F;fontColor=#FFFFFF;fontSize=10;arcSize=20;" value="Process infra" vertex="1">
          <mxGeometry height="24" width="160" x="1452" y="312" as="geometry" />
        </mxCell>
        <mxCell id="leg-flowable" parent="1" style="rounded=1;fillColor=#B71C1C;strokeColor=#7F0000;fontColor=#FFFFFF;fontSize=10;arcSize=20;" value="Flowable engine" vertex="1">
          <mxGeometry height="24" width="160" x="1452" y="342" as="geometry" />
        </mxCell>
        <mxCell id="leg-note" parent="1" style="text;html=1;fontSize=9;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#546E7A;whiteSpace=wrap;" value="Arrows show allowed dependency and runtime call paths only." vertex="1">
          <mxGeometry height="41" width="160" x="1452" y="366" as="geometry" />
        </mxCell>
        <mxCell id="outcome-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;fontStyle=1;arcSize=6;spacing=10;" value="Testable domain logic&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Handlers can be unit-tested without a running process engine.&lt;/font&gt;" vertex="1">
          <mxGeometry height="82" width="190" x="1438" y="432" as="geometry" />
        </mxCell>
        <mxCell id="outcome-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontColor=#0D47A1;fontSize=12;fontStyle=1;arcSize=6;spacing=10;" value="Replaceable engine boundary&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Flowable-specific code is isolated to infrastructure/process.&lt;/font&gt;" vertex="1">
          <mxGeometry height="82" width="190" x="1438" y="540" as="geometry" />
        </mxCell>
        <mxCell id="outcome-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontColor=#E65100;fontSize=12;fontStyle=1;arcSize=6;spacing=10;" value="Stable BPMN contracts&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Service-task delegate names and command types are governed contracts.&lt;/font&gt;" vertex="1">
          <mxGeometry height="82" width="190" x="1438" y="648" as="geometry" />
        </mxCell>
        <mxCell id="footer" parent="1" style="text;html=1;fontSize=11;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#546E7A;" value="Key constraint: domain modules call shared/process/port; infrastructure/process is the only Flowable-aware layer; delegates dispatch commands to domain handlers through the bus." vertex="1">
          <mxGeometry height="26" width="1190" x="232" y="840" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
