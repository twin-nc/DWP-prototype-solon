<mxfile host="Electron" agent="Codex">
  <diagram name="DIAG-12 Regulatory Audit Trail" id="diag-12">
    <mxGraphModel dx="1868" dy="945" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="932" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title and subtitle -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=22;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1A1A1A;" value="DIAG-12 — Regulatory Audit Trail: Any Question Answered in Under 10 Minutes" vertex="1">
          <mxGeometry x="120" y="18" width="1414" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;fontSize=12;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#455A64;" value="Every action, every DMN invocation, every suppression evaluation logged with actor, timestamp, and rule version. Single query returns complete account history." vertex="1">
          <mxGeometry x="120" y="54" width="1414" height="24" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
