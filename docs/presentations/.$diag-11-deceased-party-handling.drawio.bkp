          value="&lt;b&gt;Open Question — DDE-OQ-07&lt;/b&gt;&lt;br/&gt;Estate pursuit policy must be confirmed before deceased&lt;br/&gt;account management stories proceed past design.&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;(RULING-006)&lt;/font&gt;"
          vertex="1">
          <mxGeometry x="1094" y="716" width="500" height="80" as="geometry" />
        </mxCell>

