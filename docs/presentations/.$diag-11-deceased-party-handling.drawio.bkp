        <mxCell id="leg-flowable" parent="legend-panel"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B71C1C;strokeColor=#7F0000;fontColor=#FFFFFF;fontSize=11;arcSize=8;"
          value="Flowable / process engine"
