          value="&lt;b&gt;runtimeService.suspendProcessInstanceById()&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;for each active ProcessCaseLink&lt;/font&gt;"
          vertex="1">
          <mxGeometry x="450" y="278" width="260" height="64" as="geometry" />
        </mxCell>

        <!-- NO branch — Repayment plan suspended -->
        <mxCell id="p2-no-repayment" parent="phase2-lane"
