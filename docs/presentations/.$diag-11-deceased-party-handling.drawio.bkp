          value="&lt;b&gt;Active REPAYMENT_ARRANGEMENT records&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;set to SUSPENDED (not CANCELLED)&lt;/font&gt;"
