          value="&lt;b&gt;suppressionLogService.activate(&lt;br/&gt;accountIds, DECEASED_MANDATORY, confirmedBy)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Blocks DEBT_COLLECTION and NON_COLLECTION.&lt;br/&gt;Only ESTATE_ADMINISTRATION permitted.&lt;/font&gt;"
