        <mxCell id="lbl-phase-link" parent="1"
          style="text;html=1;fontSize=10;fontStyle=1;fontColor=#2E7D32;fillColor=none;strokeColor=none;align=center;"
          value="then"
          vertex="1">
          <mxGeometry x="603" y="504" width="34" height="18" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- GUARANTEE PANEL (full width, green strip)                          -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <mxCell id="guarantee-panel" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=3;fontColor=#1B5E20;fontSize=13;fontStyle=1;arcSize=3;spacing=12;align=center;"
          value="&lt;b&gt;Atomicity guarantee&lt;/b&gt; — This handler runs when an agent records a death notification. By the time Phase 2 touches Flowable, the deceased flag, communication suppression, and audit record are already committed to the database as a single atomic unit. If Phase 1 fails for any reason, nothing is saved and the agent can retry. If Phase 2 fails — including a Flowable crash or a race condition on a completing process instance — the legal protection written in Phase 1 remains intact. Flowable manages collection workflows, but it has no power to undo a database commit. The deceased flag cannot be un-set by process engine failure.&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px;font-style:normal;&quot;&gt;deceased_flagged_at / deceased_flagged_by are recorded in Phase 1 to support a future supervised unflag operation.&lt;/font&gt;"
          vertex="1">
          <mxGeometry x="60" y="716" width="1020" height="80" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
