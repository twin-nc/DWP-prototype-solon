          value="&lt;b&gt;FlowableObjectNotFoundException + any exception&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;→ log MANUAL_REVIEW_REQUIRED in AUDIT_EVENT&lt;br/&gt;→ NOT propagated&lt;/font&gt;"
