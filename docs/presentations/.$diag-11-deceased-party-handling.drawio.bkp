        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- PHASE CONNECTOR ARROW (Phase1 commit → Phase2)                    -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <mxCell id="arr-phase-link" parent="1"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;strokeWidth=3;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;startArrow=none;endArrow=block;endFill=1;"
          edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="523" as="sourcePoint" />
            <mxPoint x="640" y="523" as="targetPoint" />
